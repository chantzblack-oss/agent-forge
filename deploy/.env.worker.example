# Agent Forge — learning-feed worker configuration. Copy to .env, fill in.
# Never commit the real .env.

# Telegram bot (from @BotFather /newbot). Required.
TELEGRAM_BOT_TOKEN=123456789:AA...

# Lock the bot to your Telegram user id(s) — comma separated. REQUIRED:
# the worker refuses to start with an empty allowlist (anyone on Telegram
# could otherwise spend your API credits). Get your id from @userinfobot.
# Also required for the auto-feed push. To deliberately run an open bot
# for local development only, set FORGE_ALLOW_PUBLIC=1 instead.
TELEGRAM_ALLOWED_USERS=11111111

# Claude — required on a server (no logged-in CLI there).
ANTHROPIC_API_KEY=sk-ant-...

# Optional: only if you use cross-model teams / extra research grounding.
# GEMINI_API_KEY=AIzaSy...
# OPENAI_API_KEY=sk-proj-...

# Narration voice (edge-tts). Some nice ones: en-US-GuyNeural,
# en-US-AriaNeural, en-GB-RyanNeural, en-AU-NatashaNeural.
FORGE_TTS_VOICE=en-US-GuyNeural

# Auto-feed: seconds between the worker discovering + pushing a fresh video
# to you unprompted. 0 disables it (you only get videos you ask for).
# 21600 = every 6 hours. Mind your API spend before turning this up.
RESTOCK_EVERY=0
