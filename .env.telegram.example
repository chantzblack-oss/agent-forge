# ─────────────────────────────────────────────────────────────
# Agent Forge — Telegram bot (always-on hosting) configuration
# ─────────────────────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
#
# On a server there is no logged-in `claude`/`gemini` CLI, so the bot runs
# on the API (SDK) path and needs API keys for every model family you use.

# ── required ──────────────────────────────────────────────────

# Telegram bot token from @BotFather (/newbot).
TELEGRAM_BOT_TOKEN=123456789:AA...

# Claude (Anthropic). Required on a server — there is no CLI fallback here.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── required for cross-model teams ────────────────────────────

# Gemini. Needed by every Cross-Model team (Claude + Gemini).
# Free key: https://aistudio.google.com/apikey   (format: AIzaSy...)
GEMINI_API_KEY=AIzaSy...

# OpenAI. Needed only by Tri-Model / Triple-Model Braintrust teams (adds GPT).
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ── optional ──────────────────────────────────────────────────

# Lock the bot to specific Telegram user IDs (comma-separated). STRONGLY
# recommended — without it, anyone who finds your bot can spend your API
# credits. Get your numeric ID by messaging @userinfobot on Telegram.
# TELEGRAM_ALLOWED_USERS=11111111,22222222
